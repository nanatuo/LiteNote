<Window x:Class="SimpleNotesApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleNotesApp"
        mc:Ignorable="d"
        Title="极简便签"
        Icon="pack://application:,,,/appicon.ico"
        MinWidth="200"
        MinHeight="180"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="{Binding IsTopmost}"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource AppFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <Style x:Key="MinimalButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeDarkBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid x:Name="grid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="checkMark"
                                           Text="✓"
                                           FontSize="12"
                                           Foreground="{DynamicResource ThemeBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1"
                                                 HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                 VerticalAlignment="Center"
                                                 TextElement.Foreground="{TemplateBinding Foreground}"
                                                 Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircularCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="28" Height="28">
                            <Grid.Background>
                                <SolidColorBrush Color="#01000000"/>
                            </Grid.Background>
                            <Ellipse x:Name="circle"
                                     Width="16" Height="16"
                                     Stroke="{DynamicResource TextBrush}"
                                     StrokeThickness="1.2">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#01000000"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Stroke" Value="{DynamicResource ThemeBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="{DynamicResource CompletedTextBrush}"/>
                                <Setter TargetName="circle" Property="Stroke" Value="{DynamicResource CompletedTextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="circle" Property="Fill" Value="{DynamicResource ThemeBrush}"/>
                                <Setter TargetName="circle" Property="Stroke" Value="{DynamicResource ThemeBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="outer"
                                     Width="24" Height="24"
                                     Stroke="#CCCCCC"
                                     StrokeThickness="1"
                                     Fill="Transparent"/>
                            <Ellipse x:Name="inner"
                                     Width="20" Height="20"
                                     Fill="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource ThemeBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Border x:Name="mainBackground"
                CornerRadius="0"
                BorderThickness="1"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBrush}"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="titleBar" Grid.Row="0" Background="{DynamicResource ThemeDarkBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnMenu"
                        Grid.Column="0"
                        Style="{StaticResource MinimalButtonStyle}"
                        Click="btnMenu_Click"
                        ToolTip="菜单">
                    <Path Data="M5,7 L19,7 M5,12 L19,12 M5,17 L19,17"
                          Stroke="White"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="14" Height="14"
                          Stretch="Uniform"/>
                </Button>

                <Button Grid.Column="1"
                        Style="{StaticResource MinimalButtonStyle}"
                        Command="{Binding CloseCommand}"
                        ToolTip="关闭">
                    <Path Data="M5,5 L19,19 M19,5 L5,19"
                          Stroke="White"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="14" Height="14"
                          Stretch="Uniform"/>
                </Button>
            </Grid>

            <Popup x:Name="menuPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=btnMenu}"
                   HorizontalOffset="0"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border Background="{StaticResource MenuBackgroundBrush}"
                        BorderBrush="{StaticResource MenuBorderBrush}"
                        BorderThickness="1"
                        Padding="0,5">
                    <StackPanel>
                        <Button Content="置顶"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Command="{Binding ToggleTopmostCommand}"
                                Loaded="OnTopmostButtonLoaded"/>
                        <Button Content="透明"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Command="{Binding ToggleTransparentCommand}"
                                Loaded="OnTransparentButtonLoaded"/>
                        <Button Content="新建"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Command="{Binding CreateNewCommand}"/>
                        <Button x:Name="btnLoad"
                                Content="读取"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Click="MenuItem_Load_Click"/>
                        <Popup x:Name="loadMenuPopup" IsOpen="False" StaysOpen="False" Placement="Right" PlacementTarget="{Binding ElementName=btnLoad}">
                            <Border Background="{StaticResource MenuBackgroundBrush}"
                                    BorderBrush="{StaticResource MenuBorderBrush}"
                                    BorderThickness="1"
                                    Padding="0,5">
                                <StackPanel x:Name="loadMenuItems">
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button x:Name="btnFontColor"
                                Content="字体颜色"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Click="MenuItem_FontColor_Click"/>
                        <Popup x:Name="fontColorPopup" IsOpen="False" StaysOpen="False" Placement="Right" PlacementTarget="{Binding ElementName=btnFontColor}">
                            <Border Background="{StaticResource MenuBackgroundBrush}"
                                    BorderBrush="{StaticResource MenuBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                                <StackPanel Width="200">
                                    <TextBlock Text="预设颜色"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeDarkBrush}"
                                               Margin="0,0,0,8"/>
                                    <UniformGrid Columns="6" Margin="0,0,0,12">
                                        <Button Background="#999999" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#999999"/>
                                        <Button Background="#E57373" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#E57373"/>
                                        <Button Background="#64B5F6" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#64B5F6"/>
                                        <Button Background="#81C784" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#81C784"/>
                                        <Button Background="#FFB74D" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#FFB74D"/>
                                        <Button Background="#BA68C8" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetFontColor_Click" Tag="#BA68C8"/>
                                    </UniformGrid>
                                    <TextBlock Text="自定义颜色"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeDarkBrush}"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtCustomColor"
                                                 FontSize="12"
                                                 Padding="4,2"
                                                 BorderBrush="{StaticResource MenuBorderBrush}"
                                                 BorderThickness="1"
                                                 Text="#999999"/>
                                        <Button Grid.Column="1"
                                                Content="应用"
                                                FontSize="12"
                                                Width="50"
                                                Height="24"
                                                Margin="4,0,0,0"
                                                Background="{DynamicResource ThemeBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="ApplyCustomFontColor_Click"/>
                                    </Grid>
                                    <Border x:Name="fontColorPreview"
                                            Height="24"
                                            CornerRadius="3"
                                            Margin="0,8,0,0"
                                            Background="{DynamicResource TextBrush}">
                                        <TextBlock Text="预览文本 AaBbCc"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource CompletedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button x:Name="btnThemeColor"
                                Content="主题颜色"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Click="MenuItem_ThemeColor_Click"/>
                        <Popup x:Name="themeColorPopup" IsOpen="False" StaysOpen="False" Placement="Right" PlacementTarget="{Binding ElementName=btnThemeColor}">
                            <Border Background="{StaticResource MenuBackgroundBrush}"
                                    BorderBrush="{StaticResource MenuBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                                <StackPanel Width="200">
                                    <TextBlock Text="预设颜色"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeDarkBrush}"
                                               Margin="0,0,0,8"/>
                                    <UniformGrid Columns="6" Margin="0,0,0,12">
                                        <Button Background="#4CAF50" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#4CAF50"/>
                                        <Button Background="#2196F3" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#2196F3"/>
                                        <Button Background="#FF9800" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#FF9800"/>
                                        <Button Background="#E91E63" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#E91E63"/>
                                        <Button Background="#009688" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#009688"/>
                                        <Button Background="#546E7A" Style="{StaticResource ColorCircleButtonStyle}" Click="PresetThemeColor_Click" Tag="#546E7A"/>
                                    </UniformGrid>
                                    <TextBlock Text="自定义颜色"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeDarkBrush}"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtCustomThemeColor"
                                                 FontSize="12"
                                                 Padding="4,2"
                                                 BorderBrush="{StaticResource MenuBorderBrush}"
                                                 BorderThickness="1"
                                                 Text="#4CAF50"/>
                                        <Button Grid.Column="1"
                                                Content="应用"
                                                FontSize="12"
                                                Width="50"
                                                Height="24"
                                                Margin="4,0,0,0"
                                                Background="{DynamicResource ThemeBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="ApplyCustomThemeColor_Click"/>
                                    </Grid>
                                    <Border x:Name="themeColorPreview"
                                            Height="40"
                                            CornerRadius="3"
                                            Margin="0,8,0,0">
                                        <Border.Resources>
                                            <local:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
                                        </Border.Resources>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="20"/>
                                                <RowDefinition Height="20"/>
                                            </Grid.RowDefinitions>
                                            <Border x:Name="themePreviewTitle"
                                                    Grid.Row="0"
                                                    CornerRadius="3,3,0,0"
                                                    Background="{DynamicResource ThemeDarkBrush}"/>
                                            <Border x:Name="themePreviewBody"
                                                    Grid.Row="1"
                                                    CornerRadius="0,0,3,3"
                                                    Background="{DynamicResource BackgroundBrush}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Border>
            </Popup>

            <ListBox x:Name="lstTodoItems"
                     Grid.Row="1"
                     Margin="15"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Stretch"
                     Height="Auto"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="18"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemsSource="{Binding TodoItems}"
                     SelectedItem="{Binding SelectedItem}">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="删除" Command="{Binding DeleteCommand}"/>
                        <MenuItem Header="删除已完成" Command="{Binding DeleteCompletedCommand}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:TodoItem}">
                        <Grid Margin="0,2,0,2" Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                      Style="{StaticResource CircularCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Command="{Binding DataContext.CheckBoxChangedCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <TextBlock x:Name="displayText"
                                       Grid.Column="1"
                                       Text="{Binding Content}"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </TextBlock.InputBindings>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Setter Property="FontStyle" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource CompletedTextBrush}"/>
                                                <Setter Property="FontWeight" Value="Light"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="editText"
                                     Grid.Column="1"
                                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Padding="2,0"
                                     BorderBrush="{DynamicResource ThemeBrush}"
                                     BorderThickness="1"
                                     AcceptsReturn="False"
                                     AcceptsTab="False"
                                     GotFocus="EditTextBox_GotFocus"
                                     IsVisibleChanged="EditTextBox_IsVisibleChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Rectangle Grid.ColumnSpan="2"
                                       Height="1"
                                       Fill="{DynamicResource CompletedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2"
                    Command="{Binding AddCommand}"
                    Cursor="Hand"
                    Background="Transparent"
                    HorizontalAlignment="Left"
                    Margin="15,0,0,15">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Height="36" Margin="0,2,0,2">
                            <Grid.Background>
                                <SolidColorBrush Color="#01000000"/>
                            </Grid.Background>
                            <Grid Width="28" Height="28" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Grid.Background>
                                    <SolidColorBrush Color="#01000000"/>
                                </Grid.Background>
                                <Path x:Name="addIcon"
                                      Data="M12,5 L12,19 M5,12 L19,12"
                                      Stroke="{DynamicResource TextBrush}"
                                      StrokeThickness="2.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="addIcon" Property="Stroke" Value="{DynamicResource ThemeBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
